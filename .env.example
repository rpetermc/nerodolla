# Copy to .env and fill in your values. Never commit .env.

# ── Frontend (VITE_ prefix = bundled into client) ────────────────────────────

# WalletConnect v2 project ID — create at cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# wagyu.xyz integrator API keys (earn fee on XMR<->USDC swaps)
# Register at: wagyu.xyz/api — connect wallet, create key, set fee % + fee address
# Two keys: one for the Swap tab (0% fee), one for hedge flows (~0.5% fee)
VITE_WAGYU_API_KEY=
VITE_WAGYU_HEDGE_API_KEY=

# ── Proxy server (lighter_proxy.py) ──────────────────────────────────────────

# Lighter.xyz API base URL
LIGHTER_URL=https://mainnet.zklighter.elliot.ai

# Market ID for XMR-USD on Lighter
LIGHTER_XMR_MARKET_ID=77

# Default proxy URL baked into the APK (override in Settings at runtime)
VITE_PROXY_URL=https://proxy.example.com

# wagyu.xyz API keys (server-side, for proxy routing)
# Same keys as VITE_ versions but used by lighter_proxy.py instead of client
WAGYU_API_KEY=
WAGYU_HEDGE_API_KEY=

# ETH private key for the relay wallet — pays gas for EIP-3009 USDC transfers
# This wallet needs ETH on both Arbitrum and Ethereum mainnet
PROXY_ETH_KEY=0xyour_eth_private_key_here

# ── Monero node resilience ────────────────────────────────────────────────────

# Comma-separated fallback daemon RPC nodes, tried if primary is unreachable or unsynced.
# Defaults to two verified public nodes (node.sethforprivacy.com, opennode.xmr-tw.org).
DAEMON_RPC_FALLBACKS=http://23.137.57.100:18089,http://88.99.195.15:18089

# Comma-separated fallback LWS nodes, tried if local monero-lws is unreachable.
# WARNING: a public LWS operator sees your users' view keys. Leave empty unless
# you accept that trade-off.
MONERO_LWS_FALLBACKS=
